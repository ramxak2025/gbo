# Nginx config for iBorcuha
# Step 1: Copy as HTTP-only first (for certbot):
#   cp nginx.conf.example /etc/nginx/sites-available/iborcuha
#   ln -sf /etc/nginx/sites-available/iborcuha /etc/nginx/sites-enabled/
#   rm -f /etc/nginx/sites-enabled/default
#   nginx -t && systemctl restart nginx
#
# Step 2: Get SSL certificate:
#   certbot --nginx -d iborcuha.ru -d www.iborcuha.ru
#
# Certbot will automatically modify this config to add SSL

server {
    listen 80;
    server_name iborcuha.ru www.iborcuha.ru 93.189.231.221;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
