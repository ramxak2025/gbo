# ============================================================
# iBorcuha — Environment Variables Template
# ============================================================
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env в git!

# --- DATABASE ---
# PostgreSQL connection string
# Для VDS (локальный):
DATABASE_URL=postgresql://iborcuha:YOUR_PASSWORD@localhost:5432/iborcuha
# Для Vercel (Neon бесплатный): https://neon.tech
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# SSL для базы данных (если нужен вручную, обычно auto)
# DB_SSL=true

# --- JWT (обязательно!) ---
# Для production ОБЯЗАТЕЛЬНО сгенерируйте случайный ключ:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-generate-64-char-random-string

# --- ENCRYPTION KEY (новое в v1.1.0) ---
# Ключ для AES-256-GCM шифрования plain_password в БД.
# ОБЯЗАТЕЛЬНО сгенерируйте случайный ключ:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ВНИМАНИЕ: после установки НЕ МЕНЯЙТЕ — иначе существующие пароли не расшифруются!
ENCRYPTION_KEY=change-me-generate-32-byte-hex-string

# --- SERVER ---
PORT=3000
# NODE_ENV=production  # set for production builds

# --- CORS (опционально, для dev режима) ---
# CORS_ORIGIN=http://localhost:5173
# Для production укажите реальный домен:
# CORS_ORIGIN=https://iborcuha.ru

# --- PUSH NOTIFICATIONS (VAPID ключи) ---
# Сгенерировать: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
